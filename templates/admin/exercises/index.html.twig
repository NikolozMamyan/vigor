{% extends 'base.html.twig' %}

{% block title %}VIGOR Admin - Exercices{% endblock %}
{% block body_class %}bg-[#070707] text-white min-h-screen overflow-x-hidden{% endblock %}

{% block body %}
    {% set formData = formData|default({}) %}
    {% set isEdit = mode == 'edit' %}

    <main class="min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(204,255,0,0.08),transparent_32%),linear-gradient(180deg,#0b0b0d_0%,#050505_100%)]">
        <div class="mx-auto flex min-h-screen w-full max-w-7xl gap-6 px-6 py-6">
            <aside class="hidden w-64 shrink-0 rounded-3xl border border-white/10 bg-white/[0.03] p-5 backdrop-blur-2xl lg:block">
                <div class="flex items-center gap-3">
                    <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-app-accent/20 bg-app-accent/10 text-app-accent">
                        <i data-lucide="dumbbell" class="h-5 w-5"></i>
                    </span>
                    <span>
                        <span class="block text-sm font-black tracking-[0.22em]">VIGOR</span>
                        <span class="block text-[10px] font-bold uppercase tracking-widest text-app-muted">Admin desktop</span>
                    </span>
                </div>

                <nav class="mt-8 space-y-2">
                    <a href="{{ path('admin_exercises_index') }}" class="flex items-center gap-3 rounded-2xl bg-app-accent px-4 py-3 text-sm font-black text-black">
                        <i data-lucide="list-plus" class="h-4 w-4"></i>
                        Exercices
                    </a>
                    <a href="{{ path('vigor_app', {view: 'home'}) }}" class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm font-bold text-app-muted hover:text-white">
                        <i data-lucide="smartphone" class="h-4 w-4"></i>
                        Retour app
                    </a>
                </nav>
            </aside>

            <section class="grid min-w-0 flex-1 grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1fr)_420px]">
                <div class="min-w-0 space-y-5">
                    <header class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 backdrop-blur-2xl">
                        <div class="flex flex-wrap items-center justify-between gap-4">
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-widest text-app-accent">Catalogue exercices</p>
                                <h1 class="mt-1 text-3xl font-black tracking-tight">Tous les mouvements</h1>
                                <p class="mt-2 text-sm font-medium text-app-muted">{{ exercises|length }} exercice{{ exercises|length > 1 ? 's' : '' }} dans le catalogue.</p>
                            </div>
                            <a href="{{ path('admin_exercises_index') }}" class="inline-flex items-center gap-2 rounded-2xl bg-app-accent px-4 py-3 text-sm font-black text-black shadow-neon">
                                <i data-lucide="plus" class="h-4 w-4"></i>
                                Nouvel exercice
                            </a>
                        </div>
                    </header>

                    {% for message in app.flashes('success') %}
                        <div class="rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm font-bold text-emerald-300">{{ message }}</div>
                    {% endfor %}

                    <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-2xl">
                        <div class="grid grid-cols-[88px_minmax(220px,1.3fr)_160px_150px_120px_90px] gap-4 border-b border-white/10 px-5 py-3 text-[10px] font-black uppercase tracking-widest text-app-muted">
                            <span>ID</span>
                            <span>Nom / slug</span>
                            <span>Groupe</span>
                            <span>Equipement</span>
                            <span>Source</span>
                            <span class="text-right">Action</span>
                        </div>

                        <div class="max-h-[calc(100vh-220px)] overflow-auto">
                            {% for item in exercises %}
                                <article class="grid grid-cols-[88px_minmax(220px,1.3fr)_160px_150px_120px_90px] items-center gap-4 border-b border-white/5 px-5 py-4 text-sm hover:bg-white/[0.035]">
                                    <span class="font-mono text-xs font-bold text-app-muted">#{{ item.id }}</span>
                                    <span class="min-w-0">
                                        <span class="block truncate font-black text-white">{{ item.name }}</span>
                                        <span class="block truncate text-[11px] font-bold text-app-muted">{{ item.slug }}</span>
                                    </span>
                                    <span class="truncate font-bold text-white/90">{{ item.muscleGroup }}</span>
                                    <span class="truncate text-app-muted">{{ item.equipment }}</span>
                                    <span class="w-fit rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-[10px] font-black uppercase tracking-widest {{ item.source == 'custom' ? 'text-cyan-300' : 'text-app-accent' }}">{{ item.source }}</span>
                                    <span class="text-right">
                                        <a href="{{ path('admin_exercises_edit', {id: item.id}) }}" class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-xs font-black text-white hover:border-app-accent/40 hover:text-app-accent">
                                            Edit
                                        </a>
                                    </span>
                                </article>
                            {% else %}
                                <div class="px-5 py-10 text-center text-sm font-bold text-app-muted">Aucun exercice disponible.</div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <aside class="rounded-3xl border border-white/10 bg-[#0b0b0d]/95 p-5 shadow-2xl backdrop-blur-2xl xl:sticky xl:top-6 xl:h-fit">
                    <div class="mb-5 flex items-start justify-between gap-4">
                        <div>
                            <p class="text-[10px] font-black uppercase tracking-widest text-app-accent">{{ isEdit ? 'Update' : 'Create' }}</p>
                            <h2 class="mt-1 text-2xl font-black">{{ isEdit ? 'Modifier exercice' : 'Nouvel exercice' }}</h2>
                            {% if isEdit %}
                                <p class="mt-1 text-xs font-bold text-app-muted">ID #{{ exercise.id }} - cree le {{ exercise.createdAt|date('d/m/Y') }}</p>
                            {% else %}
                                <p class="mt-1 text-xs font-bold text-app-muted">Creation catalogue admin.</p>
                            {% endif %}
                        </div>
                        {% if isEdit %}
                            <a href="{{ path('admin_exercises_index') }}" class="rounded-xl border border-white/10 bg-white/5 p-2 text-app-muted hover:text-white" aria-label="Revenir a la creation">
                                <i data-lucide="x" class="h-4 w-4"></i>
                            </a>
                        {% endif %}
                    </div>

                    {% if error %}
                        <div class="mb-4 rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm font-bold text-rose-300">{{ error }}</div>
                    {% endif %}

                    <form method="post" action="{{ isEdit ? path('admin_exercises_update', {id: exercise.id}) : path('admin_exercises_create') }}" class="space-y-4">
                        <input type="hidden" name="_token" value="{{ csrf_token(isEdit ? 'admin_exercise_' ~ exercise.id : 'admin_exercise') }}">

                        <label class="block">
                            <span class="mb-2 block text-[10px] font-black uppercase tracking-widest text-app-muted">Nom</span>
                            <input name="name" value="{{ formData.name|default(exercise.id ? exercise.name : '') }}" maxlength="120" required class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold text-white outline-none focus:border-app-accent">
                        </label>

                        <label class="block">
                            <span class="mb-2 block text-[10px] font-black uppercase tracking-widest text-app-muted">Slug unique</span>
                            <input name="slug" value="{{ formData.slug|default(exercise.id ? exercise.slug : '') }}" maxlength="140" placeholder="auto depuis le nom" class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold text-white outline-none focus:border-app-accent">
                        </label>

                        <div class="grid grid-cols-2 gap-3">
                            <label class="block">
                                <span class="mb-2 block text-[10px] font-black uppercase tracking-widest text-app-muted">Groupe</span>
                                <input name="muscleGroup" value="{{ formData.muscleGroup|default(exercise.id ? exercise.muscleGroup : '') }}" maxlength="60" required class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold text-white outline-none focus:border-app-accent">
                            </label>

                            <label class="block">
                                <span class="mb-2 block text-[10px] font-black uppercase tracking-widest text-app-muted">Equipement</span>
                                <input name="equipment" value="{{ formData.equipment|default(exercise.id ? exercise.equipment : '') }}" maxlength="60" required class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold text-white outline-none focus:border-app-accent">
                            </label>
                        </div>

                        <label class="block">
                            <span class="mb-2 block text-[10px] font-black uppercase tracking-widest text-app-muted">Image URL</span>
                            <input name="imageUrl" value="{{ formData.imageUrl|default(exercise.id ? exercise.imageUrl : '') }}" maxlength="255" type="url" class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold text-white outline-none focus:border-app-accent">
                        </label>

                        <label class="block">
                            <span class="mb-2 block text-[10px] font-black uppercase tracking-widest text-app-muted">Source</span>
                            {% set sourceValue = formData.source|default(exercise.id ? exercise.source : 'vigor') %}
                            <select name="source" class="w-full rounded-2xl border border-white/10 bg-[#111113] px-4 py-3 text-sm font-bold text-white outline-none focus:border-app-accent">
                                <option value="vigor" {{ sourceValue == 'vigor' ? 'selected' }}>vigor</option>
                                <option value="custom" {{ sourceValue == 'custom' ? 'selected' }}>custom</option>
                            </select>
                        </label>

                        <button type="submit" class="mt-2 flex w-full items-center justify-center gap-2 rounded-2xl bg-app-accent px-5 py-4 text-sm font-black text-black shadow-neon active:scale-[0.99]">
                            <i data-lucide="{{ isEdit ? 'save' : 'plus' }}" class="h-4 w-4"></i>
                            {{ isEdit ? 'Enregistrer les modifications' : 'Creer exercice' }}
                        </button>
                    </form>
                </aside>
            </section>
        </div>
    </main>
{% endblock %}
