<section id="view-stats" class="tab-content {{ activeView == 'stats' ? 'active' }} px-6 space-y-6" data-vigor-navigation-target="view" data-view="stats">
    <div class="pt-2 flex items-center justify-between">
        <div>
            <p class="text-[10px] text-app-muted uppercase font-black tracking-widest mb-1">Tableau de bord</p>
            <h2 class="text-3xl font-black text-white tracking-tight">Analyses elite</h2>
        </div>
        <button type="button" class="w-10 h-10 rounded-full glass-panel flex items-center justify-center text-app-accent hover:bg-app-accent hover:text-black transition-all btn-bounce" aria-label="Partager les statistiques">
            <i data-lucide="share-2" class="w-4 h-4"></i>
        </button>
    </div>

    {% set periodIndex = statsAnalytics.period == 'month' ? 1 : (statsAnalytics.period == 'quarter' ? 2 : 0) %}
    <div class="flex p-1 bg-white/5 rounded-2xl relative">
        <div class="absolute top-1 bottom-1 w-[calc(33.33%-0.25rem)] bg-white/10 rounded-xl border border-white/10 transition-all" style="left: calc({{ periodIndex * 33.33 }}% + 0.25rem)"></div>
        <a href="{{ path('vigor_app', {view: 'stats', period: 'week'}) }}" class="flex-1 py-2 text-xs font-black {{ statsAnalytics.period == 'week' ? 'text-white' : 'text-app-muted' }} relative z-10 text-center">Semaine</a>
        <a href="{{ path('vigor_app', {view: 'stats', period: 'month'}) }}" class="flex-1 py-2 text-xs font-black {{ statsAnalytics.period == 'month' ? 'text-white' : 'text-app-muted' }} relative z-10 text-center">Mois</a>
        <a href="{{ path('vigor_app', {view: 'stats', period: 'quarter'}) }}" class="flex-1 py-2 text-xs font-black {{ statsAnalytics.period == 'quarter' ? 'text-white' : 'text-app-muted' }} relative z-10 text-center">Trimestre</a>
    </div>

    <div class="glass-panel rounded-[2rem] p-5 space-y-4 relative overflow-hidden">
        <div class="absolute -right-12 -top-12 w-32 h-32 bg-app-accent/5 blur-[45px] rounded-full pointer-events-none"></div>
        <div class="flex justify-between items-start relative z-10">
            <div>
                <span class="text-[9px] uppercase tracking-widest text-app-muted font-black">Volume hebdomadaire</span>
                <div class="flex items-baseline gap-1.5 mt-1">
                    <span class="text-3xl font-black text-white tabular-nums leading-none">{{ statsAnalytics.totalVolumeTons }}</span>
                    <span class="text-xs font-bold text-app-muted">T</span>
                </div>
            </div>
            <span class="text-xs font-bold {{ statsAnalytics.trendPercent >= 0 ? 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' : 'text-rose-400 bg-rose-500/10 border-rose-500/20' }} border px-2.5 py-1 rounded-full flex items-center gap-1">
                <i data-lucide="{{ statsAnalytics.trendPercent >= 0 ? 'trending-up' : 'trending-down' }}" class="w-3.5 h-3.5"></i>
                {{ statsAnalytics.trendPercent >= 0 ? '+' }}{{ statsAnalytics.trendPercent }}%
            </span>
        </div>

        <div class="h-36 flex items-end justify-between pt-6 px-1 relative">
            <div class="absolute inset-x-0 top-6 bottom-0 flex flex-col justify-between pointer-events-none opacity-10">
                <div class="border-b border-white w-full"></div>
                <div class="border-b border-white w-full"></div>
                <div class="border-b border-white w-full"></div>
            </div>
            {% for bar in statsAnalytics.volumeBars %}
                <div class="flex-1 flex flex-col items-center gap-2 group h-full justify-end">
                    <span class="text-[8px] font-black {{ bar.active|default(false) ? 'text-app-accent' : 'text-app-muted' }} opacity-0 group-hover:opacity-100 transition-opacity mb-0.5">{{ bar.kg }}kg</span>
                    <div class="stats-neon-bar w-7 bg-white/10 rounded-t-lg transition-all duration-500 relative overflow-hidden group-hover:brightness-125" style="height: {{ bar.height }}%">
                        <div class="absolute bottom-0 inset-x-0 {{ bar.active|default(false) ? 'bg-app-accent shadow-[0_0_15px_rgba(204,255,0,0.5)]' : 'bg-white/20' }} h-full"></div>
                    </div>
                    <span class="text-[9px] font-black {{ bar.active|default(false) ? 'text-app-accent' : 'text-app-muted' }}">{{ bar.label }}</span>
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="glass-panel rounded-[2rem] p-5">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-sm font-black text-white uppercase tracking-wider">Groupes muscles</h3>
            <span class="text-[10px] font-black text-app-accent uppercase tracking-widest">Anneaux</span>
        </div>
        <div class="flex items-center gap-5">
            <div class="relative w-32 h-32 shrink-0">
                <svg class="w-full h-full -rotate-90" viewBox="0 0 120 120">
                    <circle cx="60" cy="60" r="48" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="8"></circle>
                    <circle cx="60" cy="60" r="48" fill="none" stroke="{{ statsAnalytics.muscleGroups[0].color|default('#ccff00') }}" stroke-width="8" stroke-linecap="round" stroke-dasharray="302" stroke-dashoffset="{{ statsAnalytics.muscleGroups[0].dashOffset|default(302) }}"></circle>
                    <circle cx="60" cy="60" r="34" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="8"></circle>
                    <circle cx="60" cy="60" r="34" fill="none" stroke="{{ statsAnalytics.muscleGroups[1].color|default('#34d399') }}" stroke-width="8" stroke-linecap="round" stroke-dasharray="214" stroke-dashoffset="{{ statsAnalytics.muscleGroups[1].percent|default(0) > 0 ? 214 - (214 * statsAnalytics.muscleGroups[1].percent / 100)|round : 214 }}"></circle>
                    <circle cx="60" cy="60" r="20" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="8"></circle>
                    <circle cx="60" cy="60" r="20" fill="none" stroke="{{ statsAnalytics.muscleGroups[2].color|default('#22d3ee') }}" stroke-width="8" stroke-linecap="round" stroke-dasharray="126" stroke-dashoffset="{{ statsAnalytics.muscleGroups[2].percent|default(0) > 0 ? 126 - (126 * statsAnalytics.muscleGroups[2].percent / 100)|round : 126 }}"></circle>
                </svg>
                <i data-lucide="activity" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-6 h-6 text-app-accent"></i>
            </div>
            <div class="flex-1 space-y-3">
                {% for muscle in statsAnalytics.muscleGroups|slice(0, 4) %}
                    <div>
                        <div class="flex justify-between text-xs font-bold mb-1">
                            <span class="text-white">{{ muscle.name }}</span>
                            <span class="text-white">{{ muscle.kg }}kg</span>
                        </div>
                        <div class="flex justify-between text-[10px] font-black mb-1.5">
                            <span class="text-app-muted">{{ muscle.percent }}% du volume</span>
                            <span class="{{ muscle.direction == 'up' ? 'text-emerald-400' : 'text-rose-400' }}">
                                {{ muscle.deltaPercent >= 0 ? '+' }}{{ muscle.deltaPercent }}% - {{ muscle.deltaKg }}
                            </span>
                        </div>
                        <div class="h-2 rounded-full bg-white/5 overflow-hidden">
                            <div class="h-full rounded-full" style="width: {{ muscle.percent }}%; background-color: {{ muscle.color }}"></div>
                        </div>
                    </div>
                {% else %}
                    <p class="text-xs text-app-muted">Aucun groupe muscle calcule pour cette periode.</p>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="space-y-3">
        <div class="flex justify-between items-center px-1">
            <div class="flex items-center gap-2">
                <i data-lucide="award" class="w-4 h-4 text-app-accent"></i>
                <h3 class="text-xs font-black text-white uppercase tracking-widest">Progression elite</h3>
            </div>
            <span class="text-[9px] text-app-muted uppercase font-black tracking-widest">Kg & %</span>
        </div>

        <div class="grid grid-cols-2 gap-4">
            {% for record in statsAnalytics.progression %}
                <div class="glass-panel rounded-3xl p-4 space-y-3 relative overflow-hidden hover:bg-white/[0.05] transition-colors">
                    <div class="flex justify-between items-start">
                        <span class="text-[9px] text-app-muted uppercase font-black">{{ record.muscleGroup }}</span>
                        <span class="text-[10px] text-app-accent bg-app-accent/10 px-2 py-0.5 rounded font-black">{{ record.deltaKg }}</span>
                    </div>
                    <div>
                        <h4 class="text-xs font-extrabold text-white truncate">{{ record.exercise }}</h4>
                        <div class="flex items-baseline gap-1 mt-1">
                            <span class="text-2xl font-black text-white">{{ record.value }}</span>
                            <span class="text-xs font-bold text-app-muted">{{ record.unit }}</span>
                            <span class="text-[10px] font-black {{ record.direction == 'up' ? 'text-emerald-400' : 'text-rose-400' }} ml-auto flex items-center gap-0.5">
                                <i data-lucide="{{ record.direction == 'up' ? 'trending-up' : 'trending-down' }}" class="w-3 h-3"></i>{{ record.direction == 'up' ? '+' }}{{ record.deltaPercent }}%
                            </span>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="glass-panel rounded-3xl p-4 col-span-2">
                    <p class="text-xs text-app-muted">Aucun record personnel recent.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="glass-panel rounded-[2rem] p-5 space-y-4">
        <div class="flex justify-between items-center">
            <h3 class="text-sm font-black text-white uppercase tracking-wider">Pics par seance</h3>
            <span class="text-xs font-black text-app-muted">Meilleur 1RM</span>
        </div>
        <div class="relative h-40 rounded-2xl bg-black/20 border border-white/5 overflow-hidden">
            <div class="absolute inset-x-4 top-5 bottom-9 flex flex-col justify-between pointer-events-none opacity-10">
                <div class="border-b border-white w-full"></div>
                <div class="border-b border-white w-full"></div>
                <div class="border-b border-white w-full"></div>
            </div>
            {% for session in statsAnalytics.sessions %}
                <div
                    class="absolute -translate-x-1/2 translate-y-1/2 rounded-full bg-app-accent/80 shadow-[0_0_22px_rgba(204,255,0,.45)] flex items-center justify-center text-[8px] font-black text-black"
                    style="left: {{ session.x }}%; bottom: {{ session.y }}%; width: {{ session.size }}px; height: {{ session.size }}px"
                    title="{{ session.name }} - {{ session.peakExercise }} - {{ session.peakOneRepMax }}kg 1RM estime - {{ session.tons }}T"
                >
                    {{ session.peakOneRepMax }}kg
                </div>
                <div class="absolute -translate-x-1/2 bottom-2 text-center" style="left: {{ session.x }}%">
                    <span class="block text-[9px] font-black text-white">{{ session.date }}</span>
                    <span class="block text-[8px] font-bold text-app-muted">{{ session.tons }}T</span>
                </div>
            {% else %}
                <p class="absolute inset-0 flex items-center justify-center text-xs text-app-muted">Aucune seance sur cette periode.</p>
            {% endfor %}
            <div class="absolute left-4 right-4 bottom-9 border-b border-white/10"></div>
        </div>
    </div>

    <div class="glass-panel rounded-[2rem] p-5 relative overflow-hidden border border-app-accent/20">
        <div class="absolute -right-16 -bottom-16 w-36 h-36 bg-app-accent/10 blur-[45px] rounded-full pointer-events-none"></div>
        <div class="flex gap-4 items-center">
            <div class="w-14 h-14 rounded-2xl bg-app-accent/10 border border-app-accent/20 flex items-center justify-center text-app-accent shrink-0">
                <i data-lucide="sparkles" class="w-7 h-7"></i>
            </div>
            <div>
                <span class="text-[9px] uppercase tracking-widest text-app-accent font-black">Fun fact</span>
                <h4 class="text-sm font-black text-white mt-0.5 leading-tight">Exploit de la semaine</h4>
                <p class="text-xs text-app-muted mt-1 leading-relaxed">{{ statsAnalytics.funFact.text }}</p>
            </div>
        </div>
    </div>
</section>
