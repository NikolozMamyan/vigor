<section id="view-home" class="tab-content {{ activeView == 'home' ? 'active' }} px-6 space-y-6" data-vigor-navigation-target="view" data-view="home" data-controller="workout-start">
    <div class="pt-2">
        <p class="text-app-muted text-xs font-semibold uppercase tracking-widest mb-1">{{ dashboard.dateLabel }}</p>
        <h1 class="text-4xl font-extrabold tracking-tight">Pret a briser <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-app-accent to-emerald-400">tes limites ?</span></h1>
    </div>

    <div class="glass-panel rounded-[2rem] p-5 flex items-center justify-between relative overflow-hidden">
        <div class="absolute -right-10 -top-10 w-32 h-32 bg-app-accent/10 blur-[40px] rounded-full"></div>
        <div class="flex-1 z-10">
            <h2 class="text-sm text-app-muted font-medium mb-1">Activite du jour</h2>
            <div class="flex items-end gap-2 mb-2">
                <span class="text-3xl font-extrabold text-white leading-none">{{ dashboard.activity.kcal }}</span>
                <span class="text-sm font-medium text-app-muted mb-1">kcal</span>
            </div>
            <p class="text-xs text-app-muted">{{ dashboard.activity.minutes }}/{{ dashboard.activity.targetMinutes }} min d'entrainement</p>
        </div>
        <div class="relative w-24 h-24 z-10">
            <svg class="w-full h-full" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="40" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="8"></circle>
                <circle cx="50" cy="50" r="28" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="8"></circle>
                <circle data-vigor-navigation-target="outerRing" class="progress-ring__circle text-app-accent" stroke-dasharray="251.2" stroke-dashoffset="251.2" cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round"></circle>
                <circle data-vigor-navigation-target="innerRing" class="progress-ring__circle text-app-accent2" stroke-dasharray="175.9" stroke-dashoffset="175.9" cx="50" cy="50" r="28" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round"></circle>
            </svg>
            <i data-lucide="flame" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-5 h-5 text-white"></i>
        </div>
    </div>

    <div class="glass-panel rounded-[2rem] p-5 relative overflow-hidden" data-controller="weekly-activity">
        <div class="absolute -left-10 -bottom-10 w-32 h-32 bg-app-accent/10 blur-[40px] rounded-full pointer-events-none"></div>
        <div class="flex justify-between items-start mb-5 relative z-10">
            <div>
                <p class="text-app-muted text-[10px] font-bold uppercase tracking-widest mb-1">Activite de la semaine</p>
                <div class="flex items-baseline gap-2">
                    <span class="text-3xl font-extrabold text-white tabular-nums leading-none" data-weekly-activity-target="value">{{ dashboard.weekly.selectedValue }}</span>
                    <span class="text-sm font-medium text-app-muted">T</span>
                </div>
                <p class="text-[11px] text-app-muted mt-1" data-weekly-activity-target="label">{{ dashboard.weekly.selectedLabel }}</p>
            </div>
            <div class="flex items-center gap-1.5 bg-app-accent/10 border border-app-accent/20 rounded-full px-2.5 py-1">
                <i data-lucide="trending-up" class="w-3 h-3 text-app-accent"></i>
                <span class="text-[10px] font-bold text-app-accent">{{ dashboard.weekly.trendPercent >= 0 ? '+' }}{{ dashboard.weekly.trendPercent }}%</span>
                <span class="w-px h-3 bg-app-accent/25"></span>
                <span class="text-[10px] font-bold text-white tabular-nums">{{ dashboard.weekly.totalTons }}T total</span>
            </div>
        </div>
        <div class="flex items-end justify-between gap-2 h-24 relative z-10" data-weekly-activity-target="bars">
            {% for day in dashboard.weekly.days %}
                <button type="button" class="weekly-bar group flex-1 flex flex-col items-center gap-2 h-full {{ day.active|default(false) ? 'is-active' }}" data-action="weekly-activity#select" data-value="{{ day.value }}" data-label="{{ day.label }}" data-rest="{{ day.rest ? 'true' : 'false' }}">
                    <div class="weekly-bar-track relative w-full flex-1 {{ day.rest ? 'flex items-center justify-center' : 'flex items-end' }}">
                        {% if day.rest %}
                            <div class="w-1.5 h-1.5 rounded-full bg-white/20 group-hover:bg-white/40 transition-colors"></div>
                        {% else %}
                            <span class="weekly-bar-letter absolute -top-1 left-1/2 -translate-x-1/2 text-[10px] font-extrabold text-app-accent opacity-0 transition-opacity duration-300">{{ day.day }}</span>
                            <div class="weekly-bar-fill w-full rounded-t-lg bg-white/15 group-hover:bg-white/25 transition-all duration-300" style="height: {{ day.height }}%"></div>
                        {% endif %}
                    </div>
                    <span class="text-[10px] font-bold {{ day.active|default(false) ? 'text-white' : (day.rest ? 'text-app-muted/50' : 'text-app-muted') }} group-hover:text-white transition-colors">{{ day.day }}</span>
                </button>
            {% endfor %}
        </div>
    </div>

    <div class="space-y-3">
        <div class="flex justify-between items-center px-1">
            <div class="flex items-center gap-2">
                <i data-lucide="trophy" class="w-4 h-4 text-app-accent"></i>
                <h3 class="text-sm font-bold text-white uppercase tracking-wider">Records recents</h3>
            </div>
            <button type="button" class="text-app-muted text-[11px] font-bold hover:text-white transition-colors">Tout voir</button>
        </div>

        <div class="flex gap-3 overflow-x-auto no-scrollbar -mx-6 px-6 pt-2 pb-1" data-swipe-ignore style="scroll-snap-type: x mandatory;">
            {% for record in dashboard.recentRecords %}
                <article class="pr-card {{ record.new|default(false) ? 'pr-card-new' }} glass-panel rounded-2xl p-4 cursor-pointer hover:bg-white/5 transition-colors">
                    <div class="flex items-center justify-between mb-3">
                        <div class="w-8 h-8 rounded-lg {{ record.new|default(false) ? 'bg-app-accent/10 border-app-accent/30' : 'bg-white/5 border-white/10' }} border flex items-center justify-center">
                            <i data-lucide="dumbbell" class="w-4 h-4 {{ record.new|default(false) ? 'text-app-accent' : 'text-white' }}"></i>
                        </div>
                        <span class="text-[9px] font-bold text-app-muted uppercase tracking-wider">{{ record.date }}</span>
                    </div>
                    <p class="text-[10px] text-app-muted uppercase font-bold tracking-wider mb-1">{{ record.exercise }}</p>
                    <div class="flex items-baseline gap-1.5 mb-2">
                        <span class="text-2xl font-extrabold text-white tabular-nums">{{ record.value }}</span>
                        <span class="text-xs font-medium text-app-muted">{{ record.unit }}</span>
                    </div>
                    <div class="flex items-center gap-1 pt-2 border-t border-white/5">
                        <i data-lucide="arrow-up" class="w-3 h-3 text-app-accent"></i>
                        <span class="text-[10px] font-bold text-app-accent">{{ record.gain }}</span>
                        <span class="text-[10px] text-app-muted ml-auto">{{ record.previous }}</span>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
        <div class="glass-panel rounded-3xl p-5 relative overflow-hidden group hover:bg-white/5 transition-colors">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center mb-4 border border-white/10"><i data-lucide="dumbbell" class="w-5 h-5 text-white"></i></div>
            <p class="text-2xl font-bold text-white mb-0.5">{{ dashboard.stats.weeklyVolumeTons }}<span class="text-sm text-app-muted ml-1">T</span></p>
            <p class="text-[10px] text-app-muted uppercase font-bold tracking-wider">Volume Hebdo</p>
        </div>
        <div class="glass-panel rounded-3xl p-5 relative overflow-hidden group hover:bg-white/5 transition-colors">
            <div class="w-10 h-10 rounded-full bg-app-accent/10 flex items-center justify-center mb-4 border border-app-accent/20"><i data-lucide="zap" class="w-5 h-5 text-app-accent"></i></div>
            <p class="text-2xl font-bold text-white mb-0.5">{{ dashboard.stats.streakDays }}<span class="text-sm text-app-muted ml-1">Jours</span></p>
            <p class="text-[10px] text-app-muted uppercase font-bold tracking-wider">Serie actuelle</p>
        </div>
    </div>

    <div class="relative group mt-6">
        {% if dashboard.cta.active %}
            <div class="absolute -inset-0.5 bg-gradient-to-r from-app-accent to-emerald-500 rounded-[2rem] blur opacity-30 group-hover:opacity-60 transition duration-500 pulse-glow"></div>
        {% endif %}
        <button type="button" class="relative w-full glass-panel {{ dashboard.cta.active ? 'border-white/20 hover:bg-white/5' : 'border-white/10 opacity-90' }} rounded-[2rem] p-6 flex items-center justify-between transition-all" data-action="{{ dashboard.cta.active ? 'vigor-navigation#navigate' : 'workout-start#open' }}" {% if dashboard.cta.active %}data-vigor-navigation-view-param="workout"{% endif %}>
            <span class="text-left">
                <span class="inline-block px-3 py-1 {{ dashboard.cta.active ? 'bg-white/10 text-white' : 'bg-white/5 text-app-muted' }} text-[10px] font-bold uppercase tracking-widest rounded-full mb-3 border border-white/10">{{ dashboard.cta.label }}</span>
                <span class="block text-2xl font-extrabold text-white mb-1">{{ dashboard.cta.title }}</span>
                <span class="text-sm text-app-muted flex items-center gap-2"><i data-lucide="clock" class="w-3 h-3"></i> {{ dashboard.cta.meta }}</span>
            </span>
            <span class="w-14 h-14 rounded-full {{ dashboard.cta.active ? 'bg-app-accent text-black shadow-neon' : 'bg-white/10 text-white border border-white/10' }} flex items-center justify-center transform group-hover:scale-110 transition-transform duration-300">
                <i data-lucide="{{ dashboard.cta.active ? 'play' : 'plus' }}" class="w-6 h-6 {{ dashboard.cta.active ? 'fill-current ml-1' }}"></i>
            </span>
        </button>
    </div>

    <div class="fixed inset-0 z-[80] opacity-0 pointer-events-none transition-opacity duration-300" data-workout-start-target="modal">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-xl" data-action="click->workout-start#close"></div>
        <div class="absolute left-1/2 bottom-6 w-[calc(100%-2rem)] max-w-md -translate-x-1/2 glass-panel rounded-[2rem] p-5 shadow-[0_24px_80px_rgba(0,0,0,0.75)] border-white/15">
            <div class="flex items-start justify-between gap-4 mb-5">
                <div>
                    <p class="text-[10px] font-bold text-app-accent uppercase tracking-widest mb-1">Nouvelle seance</p>
                    <h3 class="text-2xl font-extrabold text-white">Choisir un depart</h3>
                </div>
                <button type="button" class="w-9 h-9 rounded-full bg-white/5 text-app-muted hover:text-white hover:bg-white/10 flex items-center justify-center transition-colors" data-action="workout-start#close" aria-label="Fermer">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            </div>

            <div class="space-y-3">
                <button type="button" class="w-full rounded-2xl bg-app-accent text-black p-4 flex items-center gap-4 shadow-neon text-left transition-transform active:scale-[0.99]" data-workout-start-target="startButton" data-action="workout-start#startFree">
                    <span class="w-11 h-11 rounded-2xl bg-black/10 flex items-center justify-center">
                        <i data-lucide="play" class="w-5 h-5 fill-current"></i>
                    </span>
                    <span class="flex-1">
                        <span class="block text-sm font-extrabold">Seance libre</span>
                        <span class="block text-[11px] font-semibold text-black/60">Demarrer maintenant et ajouter tes series.</span>
                    </span>
                </button>

                <button type="button" class="w-full rounded-2xl bg-white/5 border border-white/10 p-4 flex items-center gap-4 text-left opacity-55 cursor-not-allowed" disabled>
                    <span class="w-11 h-11 rounded-2xl bg-white/5 flex items-center justify-center">
                        <i data-lucide="calendar-days" class="w-5 h-5 text-app-muted"></i>
                    </span>
                    <span class="flex-1">
                        <span class="block text-sm font-extrabold text-white">Programme existant</span>
                        <span class="block text-[11px] font-semibold text-app-muted">Disponible quand les programmes utilisateur seront crees.</span>
                    </span>
                    <span class="text-[10px] font-bold text-app-muted uppercase tracking-widest">Bientot</span>
                </button>
            </div>
        </div>
    </div>
</section>
