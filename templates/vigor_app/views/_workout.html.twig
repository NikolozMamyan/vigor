<section id="view-workout" class="tab-content {{ activeView == 'workout' ? 'active' }} px-0 space-y-6" data-vigor-navigation-target="view" data-view="workout">
    <div class="relative w-full h-80 -mt-24">
        <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=1470&auto=format&fit=crop" alt="Seance developpe couche" class="w-full h-full object-cover opacity-60 mix-blend-luminosity">
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-[#050505]"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/40 to-transparent"></div>
        <div class="absolute top-28 left-6 flex gap-2">
            <span class="glass-panel px-3 py-1.5 rounded-full text-[10px] font-bold text-white uppercase tracking-widest border-white/20 flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-app-accent animate-pulse"></span> En cours
            </span>
        </div>
        <div class="absolute bottom-4 left-6 right-6">
            <span class="text-app-accent text-[10px] font-bold uppercase tracking-widest mb-2 block">Exercice 1/6 - Barre Olympique</span>
            <h2 class="text-4xl font-extrabold text-white leading-tight drop-shadow-lg">Developpe <br>Couche</h2>
        </div>
    </div>

    <div class="px-6 space-y-4">
        <div class="flex justify-between items-end mb-2">
            <h3 class="text-sm font-semibold text-app-muted uppercase tracking-wider">Objectif : 3 x 8-10</h3>
            <button type="button" class="text-app-accent text-xs font-bold bg-app-accent/10 px-3 py-1 rounded-full">Historique</button>
        </div>

        {% for set in sets %}
            <div class="set-row glass-panel rounded-2xl p-4 flex items-center justify-between group">
                <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm font-bold text-app-muted group-hover:text-white transition-colors">{{ set.number }}</div>
                    <div class="flex flex-col">
                        <span class="text-[10px] text-app-muted uppercase font-semibold mb-1">PRC: {{ set.previous }}</span>
                        <div class="flex items-baseline gap-1">
                            <input type="number" inputmode="decimal" value="{{ set.weight }}" placeholder="80" aria-label="Poids serie {{ set.number }}" class="data-input w-14 text-2xl font-extrabold text-white text-center pb-1">
                            <span class="text-app-muted font-medium text-sm mr-2">kg</span>
                            <span class="text-white/30 text-lg mx-1">x</span>
                            <input type="number" inputmode="numeric" value="{{ set.reps }}" placeholder="8" aria-label="Repetitions serie {{ set.number }}" class="data-input w-12 text-2xl font-extrabold text-white text-center pb-1">
                            <span class="text-app-muted font-medium text-sm">reps</span>
                        </div>
                    </div>
                </div>
                <button type="button" class="check-btn w-12 h-12 rounded-2xl border-2 border-white/10 bg-white/5 flex items-center justify-center relative overflow-hidden" data-action="rest-timer#toggleSet">
                    <i data-lucide="check" class="check-icon w-6 h-6 text-transparent relative z-10 transition-colors duration-300"></i>
                </button>
            </div>
        {% endfor %}

        <button type="button" class="w-full py-4 text-xs font-bold text-app-muted hover:text-white border border-dashed border-white/20 rounded-2xl flex items-center justify-center gap-2 transition-colors mt-2 bg-white/5 hover:bg-white/10">
            <i data-lucide="plus" class="w-4 h-4"></i> AJOUTER UNE SERIE
        </button>
    </div>
</section>
