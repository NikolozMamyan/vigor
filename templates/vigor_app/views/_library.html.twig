<section id="view-library" class="tab-content {{ activeView == 'library' ? 'active' }} px-6 space-y-6" data-vigor-navigation-target="view" data-view="library" data-controller="exercise-search">
    <div class="pt-2">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-3xl font-extrabold">Mouvements</h2>
            <button type="button" class="w-10 h-10 rounded-2xl bg-app-accent text-black flex items-center justify-center shadow-neon" data-action="exercise-search#openCreate" aria-label="Creer un exercice">
                <i data-lucide="plus" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="relative group">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                <i data-lucide="search" class="w-5 h-5 text-app-muted group-focus-within:text-white transition-colors"></i>
            </div>
            <input type="search" placeholder="Rechercher par muscle, nom..." class="w-full glass-panel text-white pl-12 pr-12 py-4 rounded-2xl focus:outline-none focus:border-app-accent focus:shadow-neon transition-all text-sm font-medium placeholder-app-muted" data-exercise-search-target="input" data-action="input->exercise-search#search">
            <div class="absolute inset-y-0 right-2 flex items-center">
                <button type="button" class="w-8 h-8 rounded-xl bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors" aria-label="Filtres">
                    <i data-lucide="sliders-horizontal" class="w-4 h-4 text-white"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="flex gap-4 overflow-x-auto no-scrollbar pb-2 -mx-6 px-6" data-swipe-ignore>
        {% for category in exerciseCatalog.categories %}
            <button type="button" class="flex flex-col items-center gap-2 cursor-pointer group min-w-[70px]">
                <span class="w-16 h-16 rounded-full glass-panel {{ category.active ? 'border-app-accent shadow-neon' : 'border-white/10' }} flex items-center justify-center group-hover:scale-105 transition-transform">
                    <i data-lucide="{{ category.icon }}" class="w-6 h-6 {{ category.active ? 'text-app-accent' : 'text-white/80' }}"></i>
                </span>
                <span class="text-[10px] font-bold {{ category.active ? 'text-white' : 'text-app-muted' }}">{{ category.label }}</span>
            </button>
        {% endfor %}
    </div>

    <p class="hidden glass-panel rounded-2xl p-4 text-sm text-app-muted" data-exercise-search-target="empty">Aucun mouvement trouve.</p>

    <div class="grid grid-cols-2 gap-4" data-exercise-search-target="results">
        {% for exercise in exerciseCatalog.exercises %}
            <article class="glass-panel rounded-[1.5rem] overflow-hidden group cursor-pointer hover:border-app-accent/50 transition-colors p-1">
                <div class="h-32 rounded-t-[1.2rem] rounded-b-xl bg-zinc-900 relative overflow-hidden">
                    <img src="{{ exercise.image }}" alt="{{ exercise.name }}" class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-500 group-hover:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                    <div class="absolute bottom-2 left-3">
                        <span class="bg-white/20 backdrop-blur-md text-[9px] font-bold text-white px-2 py-0.5 rounded uppercase">{{ exercise.tag }}</span>
                        {% if exercise.isCustom %}
                            <span class="bg-app-accent text-black text-[9px] font-extrabold px-2 py-0.5 rounded uppercase ml-1">Custom</span>
                        {% endif %}
                    </div>
                </div>
                <div class="p-3">
                    <h4 class="font-extrabold text-sm text-white mb-0.5">{{ exercise.name }}</h4>
                    <p class="text-[10px] text-app-muted uppercase font-semibold">{{ exercise.category }}</p>
                </div>
            </article>
        {% else %}
            <div class="col-span-2 glass-panel rounded-2xl p-5 text-center">
                <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-3">
                    <i data-lucide="search" class="w-5 h-5 text-app-muted"></i>
                </div>
                <p class="text-sm font-bold text-white mb-1">Aucun mouvement disponible</p>
                <p class="text-xs text-app-muted">Ajoute un mouvement custom ou recharge la bibliotheque.</p>
            </div>
        {% endfor %}
    </div>

    <div class="fixed inset-0 z-[80] opacity-0 pointer-events-none transition-opacity duration-300" data-exercise-search-target="modal">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-xl" data-action="click->exercise-search#closeCreate"></div>
        <div class="absolute left-1/2 bottom-6 w-[calc(100%-2rem)] max-w-md -translate-x-1/2 glass-panel rounded-[2rem] p-5 shadow-[0_24px_80px_rgba(0,0,0,0.75)] border-white/15">
            <div class="flex items-start justify-between gap-4 mb-5">
                <div>
                    <p class="text-[10px] font-bold text-app-accent uppercase tracking-widest mb-1">Exercice custom</p>
                    <h3 class="text-2xl font-extrabold text-white">Ajouter un mouvement</h3>
                </div>
                <button type="button" class="w-9 h-9 rounded-full bg-white/5 text-app-muted hover:text-white hover:bg-white/10 flex items-center justify-center transition-colors" data-action="exercise-search#closeCreate" aria-label="Fermer">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            </div>
            <div class="space-y-3">
                <input type="text" placeholder="Nom" class="w-full glass-panel rounded-2xl px-4 py-4 text-white font-bold focus:outline-none focus:border-app-accent" data-exercise-search-target="name">
                <input type="text" placeholder="Groupe musculaire" class="w-full glass-panel rounded-2xl px-4 py-4 text-white font-bold focus:outline-none focus:border-app-accent" data-exercise-search-target="muscleGroup">
                <input type="text" placeholder="Equipement" class="w-full glass-panel rounded-2xl px-4 py-4 text-white font-bold focus:outline-none focus:border-app-accent" data-exercise-search-target="equipment">
                <input type="url" placeholder="Image URL optionnelle" class="w-full glass-panel rounded-2xl px-4 py-4 text-white font-bold focus:outline-none focus:border-app-accent" data-exercise-search-target="imageUrl">
                <button type="button" class="w-full rounded-2xl bg-app-accent text-black py-4 text-sm font-extrabold shadow-neon" data-action="exercise-search#createCustom">
                    Creer l'exercice
                </button>
            </div>
        </div>
    </div>
</section>
