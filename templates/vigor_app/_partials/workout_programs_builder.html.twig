{#
    templates/vigor_app/_partials/workout_programs_builder.html.twig

    Modal builder de programme — contrôleur workout-programs.
    Inclus depuis la vue workout (écran sans séance active).
#}

<div class="fixed inset-0 z-[90] opacity-0 pointer-events-none transition-opacity duration-300"
     data-workout-programs-target="modal">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-2xl"
         data-action="click->workout-programs#closeCreate"></div>

    <div class="absolute inset-0 mx-auto max-w-md bg-[#050505] border-x border-white/5 shadow-2xl overflow-hidden flex flex-col"
         data-workout-programs-builder-tab="library">

        <header class="shrink-0 pt-[max(2.5rem,env(safe-area-inset-top))] pb-4 px-5 z-20 bg-gradient-to-b from-[#050505] via-[#050505]/95 to-transparent">
            <div class="flex items-center justify-between mb-4">
                <button type="button"
                        class="w-10 h-10 rounded-full glass-panel flex items-center justify-center text-app-muted hover:text-white transition-colors"
                        data-action="workout-programs#closeCreate"
                        aria-label="Fermer">
                    <i data-lucide="chevron-down" class="w-5 h-5"></i>
                </button>
                <div class="flex-1 px-4">
                    <input id="program-name"
                           type="text"
                           value="Push Day - Force"
                           placeholder="Nom du programme"
                           class="neo-input text-lg font-extrabold"
                           data-workout-programs-target="name">
                </div>
                <button type="button"
                        class="w-10 h-10 rounded-full glass-panel flex items-center justify-center text-app-muted hover:text-white transition-colors"
                        data-action="workout-programs#resetCreateForm"
                        aria-label="Réinitialiser">
                    <i data-lucide="rotate-ccw" class="w-5 h-5"></i>
                </button>
            </div>

            <div class="flex p-1 bg-white/5 rounded-2xl relative">
                <div class="builder-tab-indicator absolute top-1 bottom-1 w-[calc(50%-0.25rem)] bg-white/10 rounded-xl transition-all duration-300 ease-out left-1 border border-white/10"></div>
                <button type="button"
                        class="builder-tab-button flex-1 py-2.5 text-sm font-bold text-white relative z-10 transition-colors"
                        data-builder-tab-button="library"
                        data-action="workout-programs#showLibrary">
                    Bibliothèque
                </button>
                <button type="button"
                        class="builder-tab-button flex-1 py-2.5 text-sm font-bold text-app-muted relative z-10 transition-colors flex items-center justify-center gap-2"
                        data-builder-tab-button="config"
                        data-action="workout-programs#showConfig">
                    Réglages
                    <span class="builder-config-badge hidden bg-app-accent text-black text-[10px] px-1.5 py-0.5 rounded-full font-extrabold leading-none">0</span>
                </button>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto no-scrollbar pb-28 relative">
            <div class="builder-tab-content active px-5 space-y-5" data-builder-tab="library">
                <div class="sticky top-0 z-10 pb-2 pt-1 bg-[#050505]">
                    <div class="relative">
                        <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-app-muted"></i>
                        <input id="program-exercise-search"
                               type="search"
                               placeholder="Chercher un exercice..."
                               class="w-full rounded-2xl glass-panel pl-11 pr-4 py-3.5 text-sm font-bold text-white focus:border-app-accent outline-none transition-colors"
                               data-workout-programs-target="search"
                               data-action="input->workout-programs#filterExercises">
                    </div>
                    <div class="flex gap-2 overflow-x-auto no-scrollbar mt-3 pb-1"
                         data-workout-programs-target="counter">
                        <button type="button" class="shrink-0 px-4 py-1.5 rounded-full bg-white/10 text-white text-xs font-bold border border-white/10">0 sélection</button>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3" data-workout-programs-target="exerciseOptions"></div>
            </div>

            <div class="builder-tab-content px-5 space-y-4" data-builder-tab="config">
                <div class="mt-10 flex flex-col items-center justify-center text-center opacity-60"
                     data-workout-programs-target="emptySelection">
                    <div class="w-16 h-16 rounded-full glass-panel flex items-center justify-center mb-4">
                        <i data-lucide="dumbbell" class="w-8 h-8 text-app-muted"></i>
                    </div>
                    <p class="font-bold text-white">Aucun exercice</p>
                    <p class="text-xs text-app-muted mt-1">Sélectionne des exercices dans la bibliothèque</p>
                    <button type="button"
                            class="mt-4 px-5 py-2 rounded-full glass-panel text-xs font-bold text-white"
                            data-action="workout-programs#showLibrary">
                        Aller à la bibliothèque
                    </button>
                </div>

                <div class="space-y-3 pb-8" data-workout-programs-target="selectedList"></div>
            </div>
        </main>

        <nav class="builder-bottom-nav app-bottom-nav fixed left-1/2 -translate-x-1/2 w-[85%] max-w-[320px] glass-panel rounded-full z-50 shadow-2xl border border-white/20 backdrop-blur-3xl"
             aria-label="Sélection du programme">
            <div class="flex items-center justify-between gap-2 px-2 py-2">
                <div class="flex min-w-0 items-center gap-3 pl-2">
                    <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center relative shrink-0">
                        <i data-lucide="layers" class="w-5 h-5 text-white"></i>
                        <span class="builder-floating-counter absolute -top-1 -right-1 bg-app-accent text-black text-[10px] w-5 h-5 flex items-center justify-center rounded-full font-extrabold border-2 border-[#050505] transition-transform duration-300 scale-0">0</span>
                    </div>
                    <div class="min-w-0">
                        <span class="block text-[9px] font-bold text-app-muted uppercase tracking-widest">Sélection</span>
                        <span class="builder-floating-text block text-xs font-extrabold text-white truncate">0 exercice</span>
                    </div>
                </div>

                <button type="button"
                        class="builder-main-action btn-press h-12 px-5 rounded-full bg-white/10 text-white text-sm font-extrabold transition-all duration-300 shrink-0"
                        data-action="workout-programs#mainAction">
                    Configurer
                </button>
            </div>
        </nav>
    </div>
</div>
