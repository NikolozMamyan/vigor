<header class="app-header px-6 py-4 flex justify-between items-center z-30 absolute top-0 w-full bg-gradient-to-b from-black/80 to-transparent">
    <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center border border-white/10 relative">
            <div class="absolute inset-0 bg-app-accent opacity-20 blur-md rounded-full"></div>
            <i data-lucide="activity" class="w-4 h-4 text-app-accent relative z-10"></i>
        </div>
        <span class="text-sm font-extrabold tracking-[0.24em]">VIGOR</span>
    </div>

    <button
        type="button"
        class="relative group cursor-pointer"
        data-action="vigor-navigation#navigate"
        data-vigor-navigation-view-param="profile"
        aria-label="Ouvrir le profil"
    >
        <span class="block w-10 h-10 rounded-full border-2 border-white/10 overflow-hidden relative z-10 group-hover:border-app-accent transition-colors">
            <img src="https://placehold.co/100x100/18181b/ccff00?text=AX" alt="Avatar" class="w-full h-full object-cover">
        </span>
        <span class="absolute bottom-0 right-0 w-3 h-3 bg-app-accent rounded-full border-2 border-black z-20 shadow-[0_0_8px_rgba(204,255,0,0.8)]"></span>
    </button>
</header>
